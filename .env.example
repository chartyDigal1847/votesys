APP_NAME=VoteSys
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://votesys.deoris.test
# Must be this module's own origin (not https://deoris.test). Used for assets/URLs only.
# XAMPP path example: APP_URL=http://localhost/VoteSys/public

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=votesys_db
DB_USERNAME=root
DB_PASSWORD=

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.deoris.test
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=none

# ── Queue — set to redis for production, database for local dev ───────────────
QUEUE_CONNECTION=database

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_STORE=database

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Broadcasting (Laravel Reverb for WebSocket live results) ──────────────────
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=votesys
REVERB_APP_KEY=votesys-key
REVERB_APP_SECRET=change-me-in-production
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

# ── VoteSys SOA Service Identity ──────────────────────────────────────────────
VOTESYS_SERVICE_NAME=VoteSys
VOTESYS_SERVICE_KEY=votesys-service
VOTESYS_SERVICE_URL=https://votesys.deoris.test
VOTESYS_API_VERSION=v1

# ── DEORIS Portal Integration ─────────────────────────────────────────────────
# URL of the DEORIS portal that embeds this module via iframe SSO.
APP_PORTAL_URL=https://deoris.test
AUTH_SERVICE_URL=https://deoris.test
DEORIS_PORTAL_URL=https://deoris.test
AUTH_SERVICE_VERIFY_SSL=false

# Shared secret used to sign HMAC-SHA256 event envelopes sent to the Event Hub.
# Must match VOTESYS_EVENT_SECRET on the DEORIS portal side.
VOTESYS_EVENT_SECRET=change-me-votesys
VOTESYS_SEARCH_TOKEN=change-me-votesys-search-token

# Set to true only in local development to allow X-VoteSys-Dev bypass header.
VOTESYS_ALLOW_DEV_HEADERS=true

# ── Named Queues (Redis queue names) ─────────────────────────────────────────
VOTESYS_QUEUE_ELECTIONS=votesys-elections
VOTESYS_QUEUE_VOTING=votesys-voting
VOTESYS_QUEUE_NOTIFICATIONS=votesys-notifications
VOTESYS_QUEUE_ANALYTICS=votesys-analytics
VOTESYS_QUEUE_EVENTS=votesys-events

# ── Redis Pub/Sub Channels ────────────────────────────────────────────────────
VOTESYS_REDIS_CHANNEL_ELECTIONS=election.events
VOTESYS_REDIS_CHANNEL_VOTING=voting.notifications
VOTESYS_REDIS_CHANNEL_RESULTS=results.live

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="votesys@deoris.test"
MAIL_FROM_NAME="${APP_NAME}"

# ── Filesystem ────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ---------------------------------------------------------------------------
# Production public config template (copy values into .env on the VPS)
# ---------------------------------------------------------------------------
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://votesys.deoris.net
# LOG_LEVEL=warning
# DB_HOST=mysql
# DB_DATABASE=votesys_db
# DB_USERNAME=votesys
# DB_PASSWORD=
# SESSION_ENCRYPT=true
# SESSION_DOMAIN=.deoris.net
# QUEUE_CONNECTION=redis
# CACHE_STORE=redis
# REDIS_HOST=redis
# REVERB_APP_KEY=
# REVERB_APP_SECRET=
# REVERB_HOST=deoris.net
# REVERB_PORT=443
# REVERB_SCHEME=https
# VOTESYS_SERVICE_URL=https://votesys.deoris.net
# APP_PORTAL_URL=https://deoris.net
# AUTH_SERVICE_URL=https://deoris.net
# DEORIS_PORTAL_URL=https://deoris.net
# AUTH_SERVICE_VERIFY_SSL=true
# VOTESYS_EVENT_SECRET=
# VOTESYS_SEARCH_TOKEN=
# VOTESYS_ALLOW_DEV_HEADERS=false
